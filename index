<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Steam WebOS Bootloader</title>
    <style>
        body { background: #0a0a0f; color: #9b51e0; font-family: monospace; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        .box { border: 2px solid #512d6d; padding: 25px; text-align: center; background: #14141e; border-radius: 6px; }
    </style>
</head>
<body>
    <div class="box">
        <div>[ STEAM WEBOS ]</div>
        <div id="status" style="color: #fff; margin-top: 10px;">Запуск локального хостинга...</div>
    </div>

    <script>
        window.addEventListener('DOMContentLoaded', () => {
            const status = document.getElementById('status');
            
            // Стучимся к нашему мини-скрипту на ПК, чтобы он поднял основной хостинг
            fetch('http://127.0.0.1:8080/boot')
                .then(res => res.json())
                .then(data => {
                    status.innerHTML = '<span style="color: #55ff55;">[УСПЕХ] Локальный хостинг запущен!</span>';
                    // Через секунду автоматически перенаправляем Стим на наш только что поднятый локальный сервер
                    setTimeout(() => {
                        window.location.href = 'http://127.0.0.1:8090/index.html';
                    }, 1000);
                })
                .catch(err => {
                    status.innerHTML = '<span style="color: #ff5555;">[ОШИБКА] Запусти фоновый скрипт на ПК!</span>';
                });
        });
    </script>
</body>
</html>
